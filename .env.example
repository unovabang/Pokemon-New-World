# Base de données (Railway injecte DATABASE_URL quand tu relies le service PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/railway

# Secret JWT (obligatoire en production)
JWT_SECRET=un-secret-long-et-aleatoire

# Créer le premier admin au premier démarrage (optionnel, puis retirer en prod)
SEED_ADMIN_EMAIL=admin@pokemonnewworld.com
SEED_ADMIN_PASSWORD=ChoisirUnMotDePasseFort

# Cloudflare R2 (upload fichiers volumineux — jeu, patch, launcher)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key-id
R2_SECRET_ACCESS_KEY=your-secret-access-key
R2_BUCKET_NAME=pokemon-new-world
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Commit/push automatique des JSON config après sauvegarde admin (local ou production)
AUTO_COMMIT_CONFIG=true
AUTO_PUSH_CONFIG=true
# En production (Railway) : créer un token GitHub (Settings > Developer settings > Personal access tokens)
# avec la permission "repo", puis l'ajouter dans Railway Variables comme GITHUB_TOKEN.
# Optionnel : GITHUB_REPO=Jiromk/Pokemon-New-World-2.0  et  GITHUB_BRANCH=main
# GITHUB_TOKEN=ghp_xxxx
